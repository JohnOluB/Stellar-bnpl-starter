{
    "name": "stellar-bnpl-starter",
    "version": "1.0.0",
    "description": "Full-stack Buy Now Pay Later starter kit on Stellar and Soroban",
    "private": true,
    "scripts": {
      "dev": "next dev",
      "build": "next build",
      "start": "next start",
      "test": "vitest run",
      "test:integration": "vitest run tests/integration",
      "typecheck": "tsc --noEmit",
      "lint": "eslint src/**/*.ts src/**/*.tsx",
      "format": "prettier --write src/**/*.{ts,tsx}",
      "contracts:deploy": "ts-node scripts/deploy.ts"
    },
    "dependencies": {
      "@creit.tech/stellar-wallets-kit": "^0.9.0",
      "@stellar/stellar-sdk": "^11.0.0",
      "next": "14.2.0",
      "react": "^18.3.0",
      "react-dom": "^18.3.0",
      "zod": "^3.21.4"
    },
    "devDependencies": {
      "@types/node": "^20.4.2",
      "@types/react": "^18.3.0",
      "@types/react-dom": "^18.3.0",
      "@vitest/coverage-v8": "^0.33.0",
      "autoprefixer": "^10.4.14",
      "eslint": "^8.45.0",
      "eslint-config-next": "14.2.0",
      "postcss": "^8.4.27",
      "prettier": "^3.0.0",
      "tailwindcss": "^3.3.3",
      "ts-node": "^10.9.1",
      "typescript": "^5.1.6",
      "vitest": "^0.33.0"
    }
  }